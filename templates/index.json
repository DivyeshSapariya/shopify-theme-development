{
  "sections": {
    "hero": {
      "type": "builder-container",
      "settings": {
        "container_width": "boxed",
        "direction": "row",
        "direction_mobile": "column",
        "align_items": "center",
        "padding_top": 80,
        "padding_bottom": 80,
        "padding_top_mobile": 48,
        "padding_bottom_mobile": 48,
        "gap": 40,
        "gap_mobile": 24,
        "background_color": "#f5f5f5"
      },
      "blocks": {
        "col_image": {
          "type": "column",
          "settings": {
            "width": 50,
            "width_mobile": 100
          },
          "blocks": {
            "hero_image": {
              "type": "image",
              "settings": {
                "alt_text": "Hero image"
              }
            }
          },
          "block_order": ["hero_image"]
        },
        "col_content": {
          "type": "column",
          "settings": {
            "width": 50,
            "width_mobile": 100
          },
          "blocks": {
            "hero_heading": {
              "type": "heading",
              "settings": {
                "heading": "Build anything with Shopify Builder",
                "heading_tag": "h1",
                "font_size": 48,
                "font_size_tablet": 40,
                "font_size_mobile": 32
              }
            },
            "hero_text": {
              "type": "paragraph",
              "settings": {
                "text": "<p>Create flexible layouts using containers, columns, and widgets — fully editable in the Theme Editor.</p>"
              }
            },
            "hero_btn": {
              "type": "button",
              "settings": {
                "label": "Shop now",
                "link": "shopify://collections/all"
              }
            }
          },
          "block_order": ["hero_heading", "hero_text", "hero_btn"]
        }
      },
      "block_order": ["col_image", "col_content"]
    }
  },
  "order": ["hero"]
}
