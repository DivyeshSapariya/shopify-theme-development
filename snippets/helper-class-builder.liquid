{% comment %}
  Builds a space-separated class string.
  @param base {string}
  @param uid {string}
  @param custom_class {string}
  @param extra_classes {string} - visibility, animation, etc.
{% endcomment %}
{%- liquid
  assign class_list = base | append: ' ' | append: base | append: '--' | append: uid

  if extra_classes != blank
    assign class_list = class_list | append: extra_classes
  endif

  if custom_class != blank
    assign class_list = class_list | append: ' ' | append: custom_class
  endif
-%}
{{- class_list -}}
