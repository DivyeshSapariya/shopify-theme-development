{% comment %}
  Sanitizes a setting value for safe CSS output.
{% endcomment %}
{%- liquid
  assign css_unit = unit | default: 'px'
  assign sanitized = ''
  assign value_str = value | append: ''

  if value_str == blank
    assign sanitized = ''
  elsif value_str contains 'px' or value_str contains '%' or value_str contains 'em' or value_str contains 'rem' or value_str contains 'vh' or value_str contains 'vw' or value_str contains 'deg' or value_str contains 'fr' or value_str contains 's'
    assign sanitized = value_str
  elsif value_str contains '#'
    assign sanitized = value_str
  elsif value_str == 'auto' or value_str == 'none' or value_str == 'inherit' or value_str == 'transparent' or value_str == 'cover' or value_str == 'contain' or value_str == 'center' or value_str == 'row' or value_str == 'column' or value_str == 'wrap' or value_str == 'nowrap' or value_str == 'flex-start' or value_str == 'flex-end' or value_str == 'stretch' or value_str == 'space-between' or value_str == 'space-around' or value_str == 'block' or value_str == 'flex' or value_str == 'grid' or value_str == 'hidden' or value_str == 'visible' or value_str == 'left' or value_str == 'right' or value_str == 'solid' or value_str == 'dashed' or value_str == 'dotted'
    assign sanitized = value_str
  elsif css_unit == blank
    assign sanitized = value_str
  else
    assign sanitized = value_str | append: css_unit
  endif
-%}
{{- sanitized -}}
