{%- style -%}
  :root {
    {%- if settings.color_primary != blank -%}
      --builder-primary: {{ settings.color_primary }};
    {%- endif -%}
    {%- if settings.color_secondary != blank -%}
      --builder-secondary: {{ settings.color_secondary }};
    {%- endif -%}
    {%- if settings.color_background != blank -%}
      --builder-background: {{ settings.color_background }};
    {%- endif -%}
    {%- if settings.font_body -%}
      --builder-font-family: {{ settings.font_body.family }}, {{ settings.font_body.fallback_families }};
      --builder-font-weight: {{ settings.font_body.weight }};
    {%- endif -%}
    {%- if settings.font_heading -%}
      --builder-font-family-heading: {{ settings.font_heading.family }}, {{ settings.font_heading.fallback_families }};
    {%- endif -%}
  }
{%- endstyle -%}
