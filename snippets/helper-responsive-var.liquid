{% comment %}
  Outputs responsive CSS variable declarations for one property.
{% endcomment %}
{%- liquid
  assign tablet_key = setting_key | append: '_tablet'
  assign mobile_key = setting_key | append: '_mobile'

  assign desktop_raw = settings[setting_key]
  assign tablet_raw = settings[tablet_key]
  assign mobile_raw = settings[mobile_key]
-%}
{%- if desktop_raw != blank -%}
  {%- capture desktop_val -%}{% render 'helper-sanitize-value', value: desktop_raw, unit: unit %}{%- endcapture -%}
  --{{ css_var }}: {{ desktop_val }};
{%- endif -%}
{%- if tablet_raw != blank -%}
  {%- capture tablet_val -%}{% render 'helper-sanitize-value', value: tablet_raw, unit: unit %}{%- endcapture -%}
  --{{ css_var }}-tablet: {{ tablet_val }};
{%- endif -%}
{%- if mobile_raw != blank -%}
  {%- capture mobile_val -%}{% render 'helper-sanitize-value', value: mobile_raw, unit: unit %}{%- endcapture -%}
  --{{ css_var }}-mobile: {{ mobile_val }};
{%- endif -%}
