{% comment %}
  Variable Engine — outputs CSS custom properties for scoped styling.
  @param settings {object}
  @param component_type {string} - container | column | widget
  @param return {string} - optional, set to 'vars' to output variable string only
{% endcomment %}
{%- capture css_variables -%}
  {%- render 'engine-spacing', settings: settings -%}

  {%- if component_type == 'container' -%}
    {%- render 'engine-layout', settings: settings, mode: 'container' -%}
    {%- render 'engine-background', settings: settings -%}
    {%- render 'engine-border', settings: settings -%}
    {%- render 'engine-shadow', settings: settings -%}
    {%- render 'engine-position', settings: settings -%}
    {%- render 'engine-visibility', settings: settings -%}
    {%- render 'engine-animation', settings: settings -%}
  {%- elsif component_type == 'column' -%}
    {%- render 'engine-layout', settings: settings, mode: 'column' -%}
    {%- render 'engine-background', settings: settings -%}
    {%- render 'engine-border', settings: settings -%}
    {%- render 'engine-shadow', settings: settings -%}
    {%- render 'engine-position', settings: settings -%}
    {%- render 'engine-visibility', settings: settings -%}
    {%- render 'engine-animation', settings: settings -%}
  {%- elsif component_type == 'widget' -%}
    {%- render 'engine-typography', settings: settings -%}
    {%- render 'engine-background', settings: settings -%}
    {%- render 'engine-border', settings: settings -%}
    {%- render 'engine-shadow', settings: settings -%}
    {%- render 'engine-position', settings: settings -%}
    {%- render 'engine-visibility', settings: settings -%}
    {%- render 'engine-animation', settings: settings -%}
    {%- render 'helper-responsive-var', settings: settings, setting_key: 'height', css_var: 'height' -%}
    {%- render 'helper-responsive-var', settings: settings, setting_key: 'width', css_var: 'width' -%}
  {%- endif -%}
{%- endcapture -%}
{%- assign css_variables = css_variables | strip | replace: '
', '' -%}
{%- if return == 'vars' -%}
  {{- css_variables -}}
{%- else -%}
  {%- render 'helper-var-attribute', variables: css_variables -%}
{%- endif -%}
