{% comment %}
  Widget wrapper — scoped CSS variables on element + HTML shell.
{% endcomment %}
{%- liquid
  assign widget_type = widget_type | default: block.type

  capture uid
    render 'helper-unique-id', source: block.id
  endcapture
  assign uid = uid | strip

  capture modifier_classes
    render 'helper-visibility-classes', settings: block.settings
    render 'helper-animation-classes', settings: block.settings
  endcapture
  assign modifier_classes = modifier_classes | strip

  capture widget_classes
    render 'helper-class-builder', base: 'builder-widget', uid: uid, custom_class: block.settings.css_class, extra_classes: modifier_classes
  endcapture
  assign widget_classes = widget_classes | strip
-%}

<div
  class="{{ widget_classes }} builder-{{ widget_type }}"
  data-builder-id="{{ uid }}"
  data-builder-type="{{ widget_type }}"
  data-builder-widget="{{ widget_type }}"
  {% render 'engine-variable', settings: block.settings, component_type: 'widget' %}
  {% render 'helper-attribute-builder', settings: block.settings %}
  {{ block.shopify_attributes }}
>
  {{ content }}
</div>
