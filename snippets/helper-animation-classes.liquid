{% comment %}
  Returns animation CSS classes from entrance animation setting.
  @param settings {object}
{% endcomment %}
{%- liquid
  assign animation_class = ''

  case settings.entrance_animation
    when 'fade_in'
      assign animation_class = 'builder-animate--fade-in'
    when 'slide_up'
      assign animation_class = 'builder-animate--slide-up'
    when 'slide_down'
      assign animation_class = 'builder-animate--slide-down'
    when 'slide_left'
      assign animation_class = 'builder-animate--slide-left'
    when 'slide_right'
      assign animation_class = 'builder-animate--slide-right'
    when 'zoom_in'
      assign animation_class = 'builder-animate--zoom-in'
    when 'zoom_out'
      assign animation_class = 'builder-animate--zoom-out'
    when 'bounce_in'
      assign animation_class = 'builder-animate--bounce-in'
    when 'rotate_in'
      assign animation_class = 'builder-animate--rotate-in'
    when 'flip_in'
      assign animation_class = 'builder-animate--flip-in'
  endcase
-%}
{{- animation_class -}}
