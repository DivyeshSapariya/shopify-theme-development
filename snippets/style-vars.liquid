{%- comment -%}
  snippets/style-vars.liquid
  ------------------------------------------------------------------
  The real bridge now: turns a section's settings into CSS variables.
  Every section calls it the same way:
    {% render 'style-vars', section: section %}

  Falls back to sensible defaults if a setting is missing, so this
  never breaks even on a section that doesn't define every setting.

  Responsive overrides (tablet/mobile) are OPTIONAL per section — if
  a section doesn't define padding_top_tablet etc., nothing breaks,
  the desktop value just carries down (see engine.css media queries).
  ------------------------------------------------------------------
{%- endcomment -%}
--pt: {{ section.settings.padding_top | default: 40 }}px;
--pb: {{ section.settings.padding_bottom | default: 40 }}px;
{%- if section.settings.padding_top_tablet %}
--pt-tablet: {{ section.settings.padding_top_tablet }}px;
{%- endif %}
{%- if section.settings.padding_bottom_tablet %}
--pb-tablet: {{ section.settings.padding_bottom_tablet }}px;
{%- endif %}
{%- if section.settings.padding_top_mobile %}
--pt-mobile: {{ section.settings.padding_top_mobile }}px;
{%- endif %}
{%- if section.settings.padding_bottom_mobile %}
--pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
{%- endif %}
{%- if section.settings.bg_color %}
--bg: {{ section.settings.bg_color }};
{%- endif %}
