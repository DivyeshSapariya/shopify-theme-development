{% comment %}
  Returns visibility modifier classes from hide-on-device settings.
  @param settings {object}
{% endcomment %}
{%- liquid
  assign visibility_classes = ''

  if settings.hide_on_desktop
    assign visibility_classes = visibility_classes | append: ' is-hidden-desktop'
  endif

  if settings.hide_on_tablet
    assign visibility_classes = visibility_classes | append: ' is-hidden-tablet'
  endif

  if settings.hide_on_mobile
    assign visibility_classes = visibility_classes | append: ' is-hidden-mobile'
  endif
-%}
{{- visibility_classes -}}
