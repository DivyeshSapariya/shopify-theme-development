{% comment %}
  Animation Engine — motion variables only. Classes applied via helper-animation-classes.
  @param settings {object}
{% endcomment %}
{%- render 'helper-responsive-var', settings: settings, setting_key: 'animation_duration', css_var: 'duration', unit: 's' -%}
{%- render 'helper-responsive-var', settings: settings, setting_key: 'animation_delay', css_var: 'delay', unit: 's' -%}
{%- if settings.animation_timing != blank -%}
  --timing: {{ settings.animation_timing }};
{%- endif -%}
{%- if settings.animation_iteration != blank -%}
  --iteration: {{ settings.animation_iteration }};
{%- endif -%}
{%- render 'helper-responsive-var', settings: settings, setting_key: 'opacity', css_var: 'opacity', unit: '' -%}
{%- render 'helper-responsive-var', settings: settings, setting_key: 'translate_x', css_var: 'translate-x' -%}
{%- render 'helper-responsive-var', settings: settings, setting_key: 'translate_y', css_var: 'translate-y' -%}
{%- render 'helper-responsive-var', settings: settings, setting_key: 'rotate', css_var: 'rotate', unit: 'deg' -%}
{%- render 'helper-responsive-var', settings: settings, setting_key: 'scale', css_var: 'scale', unit: '' -%}
