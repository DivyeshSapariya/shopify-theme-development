{%- liquid
  assign icon_size = block.settings.icon_size | default: 48
-%}

{%- capture widget_body -%}
  {%- if block.settings.icon_image != blank -%}
    {{
      block.settings.icon_image
      | image_url: width: 200
      | image_tag:
        class: 'builder-icon__img',
        loading: 'lazy',
        width: icon_size,
        height: icon_size,
        alt: block.settings.icon_alt | default: 'Icon' | escape
    }}
  {%- elsif block.settings.icon_text != blank -%}
    <span class="builder-icon__text" aria-hidden="true">{{ block.settings.icon_text | escape }}</span>
  {%- else -%}
    <span class="builder-icon__placeholder" aria-hidden="true">★</span>
  {%- endif -%}
{%- endcapture -%}

{% render 'widget-wrapper', block: block, widget_type: 'icon', content: widget_body %}

{% schema %}
{
  "name": "Icon",
  "settings": [
    { "type": "header", "content": "Content" },
    {
      "type": "image_picker",
      "id": "icon_image",
      "label": "Icon image"
    },
    {
      "type": "text",
      "id": "icon_text",
      "label": "Icon character",
      "info": "Used when no image is selected"
    },
    {
      "type": "text",
      "id": "icon_alt",
      "label": "Alt text"
    },
    { "type": "header", "content": "Style" },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Size",
      "min": 16,
      "max": 128,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color",
      "default": "#1a1a1a"
    },
    { "type": "header", "content": "Animation" },
    {
      "type": "select",
      "id": "entrance_animation",
      "label": "Entrance animation",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "fade_in", "label": "Fade in" },
        { "value": "zoom_in", "label": "Zoom in" }
      ]
    },
    {
      "type": "range",
      "id": "animation_duration",
      "label": "Duration",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "unit": "s",
      "default": 0.6
    },
    {
      "type": "range",
      "id": "animation_delay",
      "label": "Delay",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "unit": "s",
      "default": 0
    },
    { "type": "header", "content": "Visibility" },
    {
      "type": "checkbox",
      "id": "hide_on_desktop",
      "label": "Hide on desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_tablet",
      "label": "Hide on tablet",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    { "type": "header", "content": "Advanced" },
    { "type": "text", "id": "css_class", "label": "CSS class" },
    { "type": "text", "id": "aria_label", "label": "ARIA label" },
    {
      "type": "checkbox",
      "id": "aria_hidden",
      "label": "Hide from screen readers",
      "default": false
    }
  ]
}
{% endschema %}
