{%- capture widget_body -%}
  <div class="builder-paragraph__content">
    {{ block.settings.text }}
  </div>
{%- endcapture -%}

{% render 'widget-wrapper', block: block, widget_type: 'paragraph', content: widget_body %}

{% schema %}
{
  "name": "Paragraph",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Add your text here.</p>"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#666666"
    },
    { "type": "header", "content": "Animation" },
    {
      "type": "select",
      "id": "entrance_animation",
      "label": "Entrance animation",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "fade_in", "label": "Fade in" }
      ]
    },
    {
      "type": "range",
      "id": "animation_duration",
      "label": "Duration",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "unit": "s",
      "default": 0.6
    },
    {
      "type": "range",
      "id": "animation_delay",
      "label": "Delay",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "unit": "s",
      "default": 0
    },
    { "type": "header", "content": "Visibility" },
    {
      "type": "checkbox",
      "id": "hide_on_desktop",
      "label": "Hide on desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_tablet",
      "label": "Hide on tablet",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    { "type": "header", "content": "Advanced" },
    {
      "type": "text",
      "id": "css_class",
      "label": "CSS class"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "ARIA label"
    },
    {
      "type": "checkbox",
      "id": "aria_hidden",
      "label": "Hide from screen readers",
      "default": false
    }
  ]
}
{% endschema %}
