{% comment %}
  Column block — groups widgets. Layout only, no content.
{% endcomment %}

{%- capture uid -%}{%- render 'helper-unique-id', source: block.id -%}{%- endcapture -%}
{%- assign uid = uid | strip -%}
{%- capture modifier_classes -%}
  {%- render 'helper-visibility-classes', settings: block.settings -%}
  {%- render 'helper-animation-classes', settings: block.settings -%}
{%- endcapture -%}
{%- assign modifier_classes = modifier_classes | strip -%}
{%- capture column_classes -%}
  {%- render 'helper-class-builder', base: 'builder-column', uid: uid, custom_class: block.settings.css_class, extra_classes: modifier_classes -%}
{%- endcapture -%}
{%- assign column_classes = column_classes | strip -%}

<div
  class="{{ column_classes }}"
  data-builder-id="{{ uid }}"
  data-builder-type="column"
  {% render 'engine-variable', settings: block.settings, component_type: 'column' %}
  {% render 'helper-attribute-builder', settings: block.settings %}
  {{ block.shopify_attributes }}
>
  {% content_for 'blocks' %}
</div>

{% schema %}
{
  "name": "Column",
  "blocks": [
    { "type": "heading" },
    { "type": "paragraph" },
    { "type": "button" },
    { "type": "image" },
    { "type": "icon" },
    { "type": "divider" },
    { "type": "spacer" },
    { "type": "video" },
    { "type": "html" }
  ],
  "settings": [
    { "type": "header", "content": "Layout" },
    {
      "type": "range",
      "id": "width",
      "label": "Width",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "width_tablet",
      "label": "Width (tablet)",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "width_mobile",
      "label": "Width (mobile)",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "order",
      "label": "Order",
      "min": 0,
      "max": 10,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "order_mobile",
      "label": "Order (mobile)",
      "min": 0,
      "max": 10,
      "step": 1,
      "default": 0
    },
    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    { "type": "header", "content": "Background" },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "transparent"
    },
    { "type": "header", "content": "Visibility" },
    {
      "type": "checkbox",
      "id": "hide_on_desktop",
      "label": "Hide on desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_tablet",
      "label": "Hide on tablet",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    { "type": "header", "content": "Advanced" },
    { "type": "text", "id": "css_class", "label": "CSS class" },
    { "type": "text", "id": "aria_label", "label": "ARIA label" }
  ]
}
{% endschema %}
