{%- capture widget_body -%}
  {%- if block.settings.image != blank -%}
    {%- if block.settings.link != blank -%}
      <a href="{{ block.settings.link }}" class="builder-image__link">
        {{
          block.settings.image
          | image_url: width: 1600
          | image_tag:
            class: 'builder-image__img',
            loading: 'lazy',
            widths: '375, 550, 750, 1100, 1500',
            alt: block.settings.image.alt | default: block.settings.alt_text
        }}
      </a>
    {%- else -%}
      {{
        block.settings.image
        | image_url: width: 1600
        | image_tag:
          class: 'builder-image__img',
          loading: 'lazy',
          widths: '375, 550, 750, 1100, 1500',
          alt: block.settings.image.alt | default: block.settings.alt_text
      }}
    {%- endif -%}
  {%- else -%}
    <div class="builder-image__placeholder" role="img" aria-label="{{ block.settings.alt_text | default: 'Image placeholder' | escape }}"></div>
  {%- endif -%}
{%- endcapture -%}

{% render 'widget-wrapper', block: block, widget_type: 'image', content: widget_body %}

{% schema %}
{
  "name": "Image",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "alt_text",
      "label": "Alt text"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    { "type": "header", "content": "Animation" },
    {
      "type": "select",
      "id": "entrance_animation",
      "label": "Entrance animation",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "fade_in", "label": "Fade in" },
        { "value": "zoom_in", "label": "Zoom in" }
      ]
    },
    {
      "type": "range",
      "id": "animation_duration",
      "label": "Duration",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "unit": "s",
      "default": 0.6
    },
    {
      "type": "range",
      "id": "animation_delay",
      "label": "Delay",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "unit": "s",
      "default": 0
    },
    { "type": "header", "content": "Visibility" },
    {
      "type": "checkbox",
      "id": "hide_on_desktop",
      "label": "Hide on desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_tablet",
      "label": "Hide on tablet",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    { "type": "header", "content": "Advanced" },
    {
      "type": "text",
      "id": "css_class",
      "label": "CSS class"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "ARIA label"
    },
    {
      "type": "checkbox",
      "id": "aria_hidden",
      "label": "Hide from screen readers",
      "default": false
    }
  ]
}
{% endschema %}
