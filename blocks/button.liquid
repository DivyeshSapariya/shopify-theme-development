{%- liquid
  assign button_label = block.settings.label | default: 'Button'
  assign button_link = block.settings.link | default: '#'
-%}

{%- capture widget_body -%}
  <a href="{{ button_link }}" class="builder-button__link u-focus-ring">
    {{ button_label | escape }}
  </a>
{%- endcapture -%}

{% render 'widget-wrapper', block: block, widget_type: 'button', content: widget_body %}

{% schema %}
{
  "name": "Button",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Button"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Advanced"
    },
    {
      "type": "text",
      "id": "css_class",
      "label": "CSS class"
    }
  ]
}
{% endschema %}
