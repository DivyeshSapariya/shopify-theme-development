{%- liquid
  assign tag = block.settings.heading_tag | default: 'h2'
  assign heading_text = block.settings.heading | default: 'Heading'
-%}

{%- capture widget_body -%}
  <{{ tag }} class="builder-heading__text">
    {%- if block.settings.link != blank -%}
      <a href="{{ block.settings.link }}" class="builder-heading__link u-focus-ring">
        {{ heading_text | escape }}
      </a>
    {%- else -%}
      {{ heading_text | escape }}
    {%- endif -%}
  </{{ tag }}>
{%- endcapture -%}

{% render 'widget-wrapper', block: block, widget_type: 'heading', content: widget_body %}

{% schema %}
{
  "name": "Heading",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Heading"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "HTML tag",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ]
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 72,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "font_size_tablet",
      "label": "Font size (tablet)",
      "min": 12,
      "max": 72,
      "step": 1,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Font size (mobile)",
      "min": 12,
      "max": 72,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Advanced"
    },
    {
      "type": "text",
      "id": "css_class",
      "label": "CSS class"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "ARIA label"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "select",
      "id": "entrance_animation",
      "label": "Entrance animation",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "fade_in", "label": "Fade in" },
        { "value": "slide_up", "label": "Slide up" },
        { "value": "zoom_in", "label": "Zoom in" }
      ]
    },
    {
      "type": "range",
      "id": "animation_duration",
      "label": "Duration",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "unit": "s",
      "default": 0.6
    },
    {
      "type": "range",
      "id": "animation_delay",
      "label": "Delay",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "unit": "s",
      "default": 0
    },
    { "type": "header", "content": "Visibility" },
    {
      "type": "checkbox",
      "id": "hide_on_desktop",
      "label": "Hide on desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_tablet",
      "label": "Hide on tablet",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    { "type": "header", "content": "Advanced" },
    {
      "type": "text",
      "id": "css_class",
      "label": "CSS class"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "ARIA label"
    },
    {
      "type": "checkbox",
      "id": "aria_hidden",
      "label": "Hide from screen readers",
      "default": false
    }
  ]
}
{% endschema %}
