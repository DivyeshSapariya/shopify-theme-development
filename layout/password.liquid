<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ shop.name }}</title>
    {{ content_for_header }}
    {% render 'helper-theme-variables' %}
    {{ 'reset.css' | asset_url | stylesheet_tag }}
    {{ 'variables.css' | asset_url | stylesheet_tag }}
    {{ 'engine.css' | asset_url | stylesheet_tag }}
    {{ 'utilities.css' | asset_url | stylesheet_tag }}
  </head>
  <body class="builder-body template-password">
    <main id="main-content" role="main">
      {{ content_for_layout }}
    </main>
  </body>
</html>
