{%- if section.settings.show_announcement -%}
  {%- style -%}
    #shopify-section-{{ section.id }} .builder-announcement {
      --announcement-bg: {{ section.settings.background_color }};
      --announcement-color: {{ section.settings.text_color }};
    }
  {%- endstyle -%}

  <div
    class="builder-announcement"
    role="region"
    aria-label="{{ 'sections.announcement.label' | t }}"
  >
    <div class="builder-announcement__inner u-center">
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}" class="builder-announcement__link">
          {{ section.settings.text | escape }}
        </a>
      {%- else -%}
        <p class="builder-announcement__text">{{ section.settings.text | escape }}</p>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "tag": "section",
  "class": "builder-announcement-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Welcome to our store"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}
