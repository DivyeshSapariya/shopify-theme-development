{% comment %}
  Builder Container — layout section. Content lives in column blocks only.
{% endcomment %}

{%- capture uid -%}{%- render 'helper-unique-id', source: section.id -%}{%- endcapture -%}
{%- assign uid = uid | strip -%}
{%- liquid
  assign width_modifier = ''
  if section.settings.container_width == 'full'
    assign width_modifier = 'builder-container--full'
  elsif section.settings.container_width == 'boxed'
    assign width_modifier = 'builder-container--boxed'
  endif

  assign inner_classes = 'builder-container__inner'
  if section.settings.layout_type == 'grid'
    assign inner_classes = inner_classes | append: ' builder-container__inner--grid'
  endif
-%}
{%- capture modifier_classes -%}
  {%- render 'helper-visibility-classes', settings: section.settings -%}
  {%- render 'helper-animation-classes', settings: section.settings -%}
{%- endcapture -%}
{%- assign modifier_classes = modifier_classes | strip -%}

{%- capture container_classes -%}
  {%- render 'helper-class-builder', base: 'builder-container', uid: uid, custom_class: section.settings.css_class, extra_classes: modifier_classes -%}
{%- endcapture -%}
{%- assign container_classes = container_classes | strip -%}

<section
  id="{{ section.settings.css_id | default: section.id }}"
  class="{{ container_classes }} {{ width_modifier }} u-relative"
  data-builder-id="{{ uid }}"
  data-builder-type="container"
  {% render 'engine-variable', settings: section.settings, component_type: 'container' %}
  {% render 'helper-attribute-builder', settings: section.settings %}
  {{ section.shopify_attributes }}
>
  {%- if section.settings.overlay_opacity > 0 -%}
    <div class="builder-container__overlay" aria-hidden="true"></div>
  {%- endif -%}

  <div class="{{ inner_classes }}">
    {% content_for 'blocks' %}
  </div>
</section>

{% schema %}
{
  "name": "Builder Container",
  "tag": "section",
  "class": "builder-container-section",
  "blocks": [{ "type": "column" }],
  "settings": [
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "boxed",
      "options": [
        { "value": "boxed", "label": "Boxed" },
        { "value": "full", "label": "Full width" }
      ]
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "Layout type",
      "default": "flex",
      "options": [
        { "value": "flex", "label": "Flex" },
        { "value": "grid", "label": "Grid" }
      ]
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Direction",
      "default": "row",
      "options": [
        { "value": "row", "label": "Row" },
        { "value": "column", "label": "Column" }
      ]
    },
    {
      "type": "select",
      "id": "direction_tablet",
      "label": "Direction (tablet)",
      "default": "row",
      "options": [
        { "value": "row", "label": "Row" },
        { "value": "column", "label": "Column" }
      ]
    },
    {
      "type": "select",
      "id": "direction_mobile",
      "label": "Direction (mobile)",
      "default": "column",
      "options": [
        { "value": "row", "label": "Row" },
        { "value": "column", "label": "Column" }
      ]
    },
    {
      "type": "select",
      "id": "justify_content",
      "label": "Justify content",
      "default": "flex-start",
      "options": [
        { "value": "flex-start", "label": "Start" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "End" },
        { "value": "space-between", "label": "Space between" }
      ]
    },
    {
      "type": "select",
      "id": "align_items",
      "label": "Align items",
      "default": "stretch",
      "options": [
        { "value": "stretch", "label": "Stretch" },
        { "value": "flex-start", "label": "Start" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "End" }
      ]
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "gap_tablet",
      "label": "Gap (tablet)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Gap (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "text",
      "id": "inner_max_width",
      "label": "Max width",
      "default": "1200",
      "info": "Unitless number outputs px"
    },
    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "label": "Padding top (tablet)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "Padding left",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Padding right",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    { "type": "header", "content": "Background" },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0
    },
    { "type": "header", "content": "Border" },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e5e5e5"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    { "type": "header", "content": "Animation" },
    {
      "type": "select",
      "id": "entrance_animation",
      "label": "Entrance animation",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "fade_in", "label": "Fade in" },
        { "value": "slide_up", "label": "Slide up" },
        { "value": "zoom_in", "label": "Zoom in" }
      ]
    },
    {
      "type": "range",
      "id": "animation_duration",
      "label": "Duration",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "unit": "s",
      "default": 0.6
    },
    { "type": "header", "content": "Visibility" },
    {
      "type": "checkbox",
      "id": "hide_on_desktop",
      "label": "Hide on desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_tablet",
      "label": "Hide on tablet",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    { "type": "header", "content": "Advanced" },
    { "type": "text", "id": "css_id", "label": "CSS ID" },
    { "type": "text", "id": "css_class", "label": "CSS class" },
    { "type": "text", "id": "aria_label", "label": "ARIA label" }
  ],
  "presets": [
    {
      "name": "Builder Container",
      "blocks": [
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}
