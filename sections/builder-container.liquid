{% comment %}
  Builder Container — layout section. Content lives in column blocks only.
{% endcomment %}

{%- capture uid -%}{%- render 'helper-unique-id', source: section.id -%}{%- endcapture -%}
{%- capture scope_selector -%}.builder-container--{{ uid }}{%- endcapture -%}
{%- liquid
  assign width_modifier = ''
  if section.settings.container_width == 'full'
    assign width_modifier = 'builder-container--full'
  elsif section.settings.container_width == 'boxed'
    assign width_modifier = 'builder-container--boxed'
  endif
-%}
{%- capture container_classes -%}
  {%- render 'helper-class-builder', base: 'builder-container', uid: uid, custom_class: section.settings.css_class -%}
{%- endcapture -%}

{%- render 'engine-variable',
  settings: section.settings,
  scope_selector: scope_selector,
  component_type: 'container'
-%}

<section
  id="{{ section.settings.css_id | default: section.id }}"
  class="{{ container_classes }} {{ width_modifier }} u-relative"
  data-builder-id="{{ uid }}"
  data-builder-type="container"
  {{ section.shopify_attributes }}
>
  {%- if section.settings.background_color != blank or section.settings.overlay_color != blank -%}
    <div class="builder-container__overlay" aria-hidden="true"></div>
  {%- endif -%}

  <div class="builder-container__inner">
    {% content_for 'blocks' %}
  </div>
</section>

{% schema %}
{
  "name": "Builder Container",
  "tag": "section",
  "class": "builder-container-section",
  "blocks": [
    { "type": "column" }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "boxed",
      "options": [
        { "value": "boxed", "label": "Boxed" },
        { "value": "full", "label": "Full width" }
      ]
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Direction",
      "default": "row",
      "options": [
        { "value": "row", "label": "Row" },
        { "value": "column", "label": "Column" }
      ]
    },
    {
      "type": "select",
      "id": "direction_tablet",
      "label": "Direction (tablet)",
      "default": "row",
      "options": [
        { "value": "row", "label": "Row" },
        { "value": "column", "label": "Column" }
      ]
    },
    {
      "type": "select",
      "id": "direction_mobile",
      "label": "Direction (mobile)",
      "default": "column",
      "options": [
        { "value": "row", "label": "Row" },
        { "value": "column", "label": "Column" }
      ]
    },
    {
      "type": "select",
      "id": "justify_content",
      "label": "Justify content",
      "default": "flex-start",
      "options": [
        { "value": "flex-start", "label": "Start" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "End" },
        { "value": "space-between", "label": "Space between" }
      ]
    },
    {
      "type": "select",
      "id": "align_items",
      "label": "Align items",
      "default": "stretch",
      "options": [
        { "value": "stretch", "label": "Stretch" },
        { "value": "flex-start", "label": "Start" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "End" }
      ]
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "gap_tablet",
      "label": "Gap (tablet)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Gap (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "text",
      "id": "inner_max_width",
      "label": "Max width",
      "default": "1200",
      "info": "Unitless number outputs px"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "label": "Padding top (tablet)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "Padding left",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Padding right",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Advanced"
    },
    {
      "type": "text",
      "id": "css_id",
      "label": "CSS ID"
    },
    {
      "type": "text",
      "id": "css_class",
      "label": "CSS class"
    }
  ],
  "presets": [
    {
      "name": "Builder Container",
      "blocks": [
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}
