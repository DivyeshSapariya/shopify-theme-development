{%- comment -%}
  sections/feature-grid.liquid
  ------------------------------------------------------------------
  First section with BLOCKS — repeatable items the merchant can add,
  remove, and reorder in the editor without touching code. Each block
  here is one "feature" card (icon + title + text).
  ------------------------------------------------------------------
{%- endcomment -%}

<section
  class="theme-section theme-feature-grid-section"
  style="
    {% render 'style-vars', section: section %}
    --columns: {{ section.settings.columns }};
    --columns-tablet: {{ section.settings.columns_tablet }};
    --columns-mobile: {{ section.settings.columns_mobile }};
    --icon-size: {{ section.settings.icon_size }}px;
    --item-title-fs: {{ section.settings.title_size }}px;
    --item-text-fs: {{ section.settings.text_size }}px;
  "
>
  <div class="theme-section__inner theme-feature-grid-section__inner">
    {% if section.settings.heading != blank %}
      <h2 class="theme-feature-grid-section__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="theme-feature-grid">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'feature' %}
            <div class="theme-feature" {{ block.shopify_attributes }}>
              {% if block.settings.icon != blank %}
                <img class="theme-feature__icon" src="{{ block.settings.icon | image_url: width: 160 }}" alt="" loading="lazy">
              {% endif %}
              {% if block.settings.title != blank %}
                <h3 class="theme-feature__title">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.text != blank %}
                <p class="theme-feature__text">{{ block.settings.text }}</p>
              {% endif %}
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Feature grid",
  "settings": [
    { "id": "heading", "type": "text", "label": "Heading", "default": "Why shop with us" },
    { "type": "header", "content": "Typography" },
    { "id": "title_size", "type": "range", "label": "Item title size", "min": 14, "max": 28, "default": 18, "unit": "px" },
    { "id": "text_size", "type": "range", "label": "Item text size", "min": 12, "max": 20, "default": 15, "unit": "px" },
    { "type": "header", "content": "Icon" },
    { "id": "icon_size", "type": "range", "label": "Icon size", "min": 24, "max": 96, "step": 4, "unit": "px", "default": 40 },
    { "type": "header", "content": "Layout (desktop)" },
    { "id": "columns", "type": "range", "label": "Columns", "min": 1, "max": 4, "default": 3 },
    { "type": "header", "content": "Layout (tablet)" },
    { "id": "columns_tablet", "type": "range", "label": "Columns", "min": 1, "max": 3, "default": 2 },
    { "type": "header", "content": "Layout (mobile)" },
    { "id": "columns_mobile", "type": "range", "label": "Columns", "min": 1, "max": 2, "default": 1 },
    { "type": "header", "content": "Style" },
    { "id": "bg_color", "type": "color", "label": "Background color", "default": "#ffffff" },
    { "type": "header", "content": "Spacing (desktop)" },
    { "id": "padding_top", "type": "range", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 },
    { "id": "padding_bottom", "type": "range", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 },
    { "type": "header", "content": "Spacing (tablet)" },
    { "id": "padding_top_tablet", "type": "range", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48 },
    { "id": "padding_bottom_tablet", "type": "range", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48 },
    { "type": "header", "content": "Spacing (mobile)" },
    { "id": "padding_top_mobile", "type": "range", "label": "Padding top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 32 },
    { "id": "padding_bottom_mobile", "type": "range", "label": "Padding bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 32 }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "id": "icon", "type": "image_picker", "label": "Icon" },
        { "id": "title", "type": "text", "label": "Title", "default": "Free shipping" },
        { "id": "text", "type": "textarea", "label": "Text", "default": "On all orders over $50." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature grid",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}
