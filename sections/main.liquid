<section class="main-section" {{ section.shopify_attributes }}>
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h1 class="main-section__heading">{{ section.settings.heading }}</h1>
    {% endif %}

    {% if section.settings.text != blank %}
      <p class="main-section__text">{{ section.settings.text }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main",
  "tag": "section",
  "class": "main-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Start building your theme from here."
    }
  ],
  "presets": [
    {
      "name": "Main"
    }
  ]
}
{% endschema %}
