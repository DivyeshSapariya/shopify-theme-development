{%- comment -%}
  sections/test-style-vars.liquid
  ------------------------------------------------------------------
  TEMPORARY — this section only exists to prove style-vars.liquid
  works. We delete it once confirmed. It does two things:
    1. Applies the snippet's output as a real style="" attribute
       (so you can see the background color change)
    2. Prints the exact same output as visible text on the page
       (so you can read the raw CSS variable string)
  ------------------------------------------------------------------
{%- endcomment -%}

<div style="{% render 'style-vars' %}" style-test-box>
  <p><strong>If this box has a pale yellow background, the snippet is working visually.</strong></p>

  <p>Raw output from style-vars.liquid (should show --pt, --pb, --bg):</p>
  <pre>{% render 'style-vars' %}</pre>
</div>

<style>
  [style-test-box] {
    padding-top: var(--pt);
    padding-bottom: var(--pb);
    background: var(--bg);
    padding-left: 16px;
    padding-right: 16px;
  }
</style>

{% schema %}
{
  "name": "TEST — style vars"
}
{% endschema %}
