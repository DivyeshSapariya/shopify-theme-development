<div class="builder-main-search page-width">
  <h1 class="builder-main-search__title">{{ 'search.title' | t }}</h1>

  <form action="{{ routes.search_url }}" method="get" role="search" class="builder-main-search__form">
    <label for="search-input" class="u-visually-hidden">{{ 'search.placeholder' | t }}</label>
    <input
      id="search-input"
      type="search"
      name="q"
      value="{{ search.terms | escape }}"
      placeholder="{{ 'search.placeholder' | t }}"
      class="builder-main-search__input u-focus-ring"
    >
    <button type="submit" class="builder-button u-focus-ring">{{ 'search.submit' | t }}</button>
  </form>

  {%- if search.performed -%}
    <p class="builder-main-search__count">{{ 'search.results_count' | t: count: search.results_count }}</p>
    <ul class="builder-main-search__results" role="list">
      {%- for result in search.results -%}
        <li>
          <a href="{{ result.url }}">{{ result.title | escape }}</a>
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Search results",
  "tag": "section",
  "class": "builder-main-search-section",
  "settings": []
}
{% endschema %}
